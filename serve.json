{
  "public": ".",
  "rewrites": [],
  "redirects": [],
  "headers": [
    {
      "source": "**/*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    }
  ],
  "cleanUrls": false,
  "trailingSlash": false,
  "directoryListing": false
}
